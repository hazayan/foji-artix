# Maintainer: David Runge <dvzrv@archlinux.org>
# Contributor: Bartłomiej Piotrowski <bpiotrowski@archlinux.org>

pkgname=knox
pkgver=1.3.0
pkgrel=1
pkgdesc="Knox is a secret management service"
arch=(x86_64)
url="https://github.com/hazayan/knox"
license=(BSD-3)
makedepends=(go)

source=("${url}/archive/refs/tags/v${pkgver}.tar.gz")

sha256sums=("52ce972d1799ac4ffc4e38f1a0ad8d324068a1429468664035fb589475bf29ce")

prepare(){
  # Setup local caches to keep the build environment isolated
  export GOMODCACHE="${srcdir}/modcache"
  export GOCACHE="${srcdir}/go-build"
  # Download app dependencies to the local cache
  cd "${pkgname}-${pkgver}"
  go mod download -modcacherw
  mkdir -p build/
}

build() {
  cd "${pkgname}-${pkgver}"
  export CGO_ENABLED="0"
  export GOAMD64="v2"
  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export CGO_LDFLAGS="${LDFLAGS}"
  export GOFLAGS="-buildmode=pie -trimpath -buildvcs=false -mod=readonly"
  # Setup local caches and paths
  export GOMODCACHE="${srcdir}/modcache"
  export GOCACHE="${srcdir}/go-build"
  # Build all components
  go build -o build/knox ./cmd/client
  go build -o build/knox-server ./cmd/server
  go build -o build/knox-dbus ./cmd/dbus
  sudo rm -rf "${GOCACHE}" "${GOMODCACHE}"
}

package() {
  cd "${pkgname}-${pkgver}"
  install -d "${pkgdir}/etc/knox"
  install -d "${pkgdir}/var/lib/knox"
  install -Dm755 build/knox "${pkgdir}/usr/local/bin/knox"
  install -Dm755 build/knox-dbus "${pkgdir}/usr/local/bin/knox-dbus"
  install -Dm755 build/knox-server "${pkgdir}/usr/local/bin/knox-server"
}

